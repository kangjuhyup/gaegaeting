#!/bin/bash
set -euo pipefail

# k3s 복원 스크립트
# 사용법: ./restore-k3s.sh <backup-file>

if [ $# -ne 1 ]; then
    echo "사용법: $0 <backup-file>"
    echo "예제: $0 {{ backup.storage_path }}/etcd/k3s-etcd-2024-01-01-020000.db"
    exit 1
fi

BACKUP_FILE="$1"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)

if [ ! -f "$BACKUP_FILE" ]; then
    echo "❌ 백업 파일을 찾을 수 없습니다: $BACKUP_FILE"
    exit 1
fi

echo "⚠️  경고: 이 작업은 현재 클러스터 상태를 백업 시점으로 되돌립니다."
echo "백업 파일: $BACKUP_FILE"
echo ""
read -p "계속하시겠습니까? (yes/no): " -r
if [[ ! $REPLY =~ ^[Yy][Ee][Ss]$ ]]; then
    echo "복원이 취소되었습니다."
    exit 0
fi

echo "🔄 k3s 서비스 중지 중..."
systemctl stop k3s

echo "💾 현재 데이터 백업 중..."
CURRENT_BACKUP="{{ backup.storage_path }}/etcd/pre-restore-${TIMESTAMP}.db"
if [ -f "{{ k3s.data_dir }}/server/db/etcd/member/snap/db" ]; then
    cp "{{ k3s.data_dir }}/server/db/etcd/member/snap/db" "$CURRENT_BACKUP"
    echo "현재 데이터 백업 완료: $CURRENT_BACKUP"
fi

echo "📦 백업에서 복원 중..."
mkdir -p "{{ k3s.data_dir }}/server/db/etcd/member/snap"
cp "$BACKUP_FILE" "{{ k3s.data_dir }}/server/db/etcd/member/snap/db"

echo "🚀 k3s 서비스 시작 중..."
systemctl start k3s

echo "⏳ k3s가 준비될 때까지 대기 중..."
sleep 30

echo "✅ 복원 완료!"
echo ""
echo "클러스터 상태 확인:"
kubectl get nodes
kubectl get pods -A
